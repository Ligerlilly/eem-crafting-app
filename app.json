{
  "expo": {
    "name": "Eem Crafting Companion",
    "slug": "eem-crafting-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e8dfd4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eemcrafting.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app does not access your photo library.",
        "NSCameraUsageDescription": "This app does not use the camera.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e8dfd4"
      },
      "package": "com.eemcrafting.app",
      "versionCode": 2,
      "permissions": []
    },
    "plugins": [
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "0b3acce7-81d6-4227-a704-33a8067d5ae8"
      }
    }
  }
}
